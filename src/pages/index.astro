---
const title = "Reference";
const paragraph =
  "Hello. We’re a couple of creative directors. Born in MENA. Raised in the UK. Trusted by some of the best in the region. We call it Supersonic Creative.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Reference — Supersonic creative." />

    <style>
      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Regular.woff2") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Medium.woff2") format("woff2");
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Bold.woff2") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }

      :root { color-scheme: dark; }

      body {
        margin: 0;
        font-family: "ObviouslyWide", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
        background: #050508;
        color: rgba(255,255,255,.92);
      }

      .hero {
        min-height: 100svh;
        display: grid;
        place-items: center;
        position: relative;
        overflow: hidden;
        padding: 32px 18px;
      }

      .bg {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(1200px 700px at 20% 30%, rgba(140, 80, 255, .30), transparent 60%),
          radial-gradient(900px 600px at 80% 70%, rgba(255, 80, 160, .18), transparent 55%),
          linear-gradient(180deg, rgba(255,255,255,.05), transparent 35%);
      }

      .card {
        position: relative;
        z-index: 1;
        width: min(920px, 92vw);
        padding: 28px;
        border-radius: 22px;
        background: rgba(0,0,0,.32);
        border: 1px solid rgba(255,255,255,.10);
        backdrop-filter: blur(14px);
        box-shadow: 0 30px 90px rgba(0,0,0,.55);
        text-align: center;
      }

      .logo {
        width: min(780px, 92vw);
        height: auto;
        display: block;
        margin: 0 auto 14px auto;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.14);
        background: rgba(255,255,255,.06);
        font-size: 14px;
        opacity: .95;
        margin-bottom: 14px;
      }

      .dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: #7CFFB2;
        box-shadow: 0 0 18px rgba(124,255,178,.55);
      }

      p {
        margin: 0;
        font-weight: 400;
        font-size: clamp(14px, 1.35vw, 18px);
        line-height: 1.5;
        color: rgba(255,255,255,.78);
      }
    </style>
  </head>

  <body>
    <main class="hero">
      <div class="bg" aria-hidden="true"></div>

      <section class="card" aria-label="Reference coming soon">
        <!-- Put your SVG here:
             reference-site/public/brand/reference-logo.svg -->
        <img class="logo" src="/brand/reference-logo.svg" alt="Reference — Supersonic Creative" />

        <div class="pill"><span class="dot"></span> Coming soon</div>

        <p>{paragraph}</p>
      </section>
    </main>
  </body>
</html>