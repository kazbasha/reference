---
const title = "Reference";
const tagline = "Supersonic creative.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p>{tagline}</p>
      <p>Coming soon.</p>
    </main>
  </body>
</html>

<style>
  body { 
    margin: 0; 
    font-family: system-ui, -apple-system, Arial, sans-serif; 
    background: #0f0f0f; 
    color: #fff;
  }
  main { 
    min-height: 100vh; 
    display: grid; 
    place-content: center; 
    text-align: center; 
    padding: 40px; 
  }
  h1 { 
    font-size: 72px; 
    margin: 0 0 16px; 
    letter-spacing: -0.04em; 
  }
  p { 
    font-size: 20px; 
    margin: 8px 0; 
    opacity: 0.7; 
  }
</style>