---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Reference",
  description = "Reference — Supersonic creative.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <style>
      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Regular.woff2") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Medium.woff2") format("woff2");
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Bold.woff2") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }

      *, *::before, *::after {
        box-sizing: border-box;
      }

      :root {
        color-scheme: dark;
      }

      html {
        scroll-behavior: smooth;
        overflow-x: hidden;
      }

      body {
        margin: 0;
        background: #0a0a0a;
        color: #e8e4de;
        font-family: "ObviouslyWide", system-ui, -apple-system, sans-serif;
        overflow-x: hidden;
      }

      h1, h2, h3, p {
        margin: 0;
      }

      /* Grain overlay — fixed, covers entire viewport */
      .grain {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 9000;
        pointer-events: none;
        opacity: 0.038;
      }

      .grain rect {
        animation: grain-shift 9s steps(7) infinite;
      }

      @keyframes grain-shift {
        0%   { transform: translate(0,    0);    }
        14%  { transform: translate(-6%, -10%);  }
        28%  { transform: translate(4%,  -4%);   }
        42%  { transform: translate(-3%,  7%);   }
        57%  { transform: translate(6%,   3%);   }
        71%  { transform: translate(-4%, -6%);   }
        85%  { transform: translate(2%,   9%);   }
        100% { transform: translate(0,    0);    }
      }
    </style>
  </head>
  <body>
    <!-- Grain texture — feTurbulence fractalNoise -->
    <svg class="grain" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <filter id="grain-filter" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.68"
          numOctaves="3"
          stitchTiles="stitch"
        />
        <feColorMatrix type="saturate" values="0" />
      </filter>
      <!-- Oversized rect so animated translate never reveals edges -->
      <rect
        width="200%"
        height="200%"
        x="-50%"
        y="-50%"
        filter="url(#grain-filter)"
      />
    </svg>

    <slot />
  </body>
</html>
