---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Reference",
  description = "Reference — Supersonic creative.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <style is:global>
      *, *::before, *::after { cursor: none !important; }
    </style>

    <style>
      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Regular.woff2") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Medium.woff2") format("woff2");
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Bold.woff2") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }

      *, *::before, *::after {
        box-sizing: border-box;
      }

      :root {
        color-scheme: dark;
      }

      html {
        scroll-behavior: auto;
        overflow-x: hidden;
      }

      body {
        margin: 0;
        background: #0a0a0a;
        color: #e8e4de;
        font-family: "ObviouslyWide", system-ui, -apple-system, sans-serif;
        overflow-x: hidden;
        cursor: none;
      }

      h1, h2, h3, p {
        margin: 0;
      }

      /* Grain overlay — fixed, covers entire viewport */
      .grain {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 9000;
        pointer-events: none;
        opacity: 0.038;
      }


      /* Brand mark */
      .brand-mark {
        position: fixed;
        top: 24px;
        left: 24px;
        z-index: 8000;
        display: block;
        height: 32px;
        width: 32px;
        opacity: 0;
        pointer-events: none; /* always none — hover/click handled in JS */
        transition: opacity 0.4s ease, width 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .brand-mark.is-visible {
        opacity: 1;
      }

      .brand-mark__symbol,
      .brand-mark__logo {
        position: absolute;
        top: 0;
        left: 0;
        background-size: contain;
        background-repeat: no-repeat;
        background-position: left center;
        pointer-events: none;
        transition: opacity 0.25s ease, filter 0.3s ease;
        /* Convert to white for dark-background sections */
        filter: brightness(0) invert(1);
      }

      .brand-mark__symbol {
        width: 32px;
        height: 32px;
        background-image: url('/brand/reference-symbol.svg');
      }

      .brand-mark__logo {
        width: 160px;
        height: 36px;
        background-image: url('/brand/reference-logo.svg');
        opacity: 0;
        clip-path: inset(0 100% 8% 0);
        transition: opacity 0s, filter 0.3s ease;
      }

      /* JS adds .is-hovered instead of :hover */
      .brand-mark.is-hovered .brand-mark__symbol {
        opacity: 0;
      }

      .brand-mark.is-hovered .brand-mark__logo {
        opacity: 1;
        animation: logo-wipe 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }

      @keyframes logo-wipe {
        from { clip-path: inset(0 100% 8% 0); }
        to   { clip-path: inset(0 0%   8% 0); }
      }

      .brand-mark.is-hovered {
        width: 160px;
        height: 36px;
      }

      /* Inherit currentColor per section */
      .brand-mark { color: #e8e4de; }
      .brand-mark--on-light { color: #1a1a1a; }

      /* Dark mode — off-white section */
      .brand-mark--on-light .brand-mark__symbol,
      .brand-mark--on-light .brand-mark__logo {
        filter: brightness(0);
      }

      /* Custom cursor dot */
      .cursor-dot {
        position: fixed;
        top: 0;
        left: 0;
        width: 8px;
        height: 8px;
        background: #986edf;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        will-change: transform;
        opacity: 0;
        transition: opacity 0.2s ease;
      }

      /* Music toggle */
      .music-toggle {
        position: fixed;
        right: 20px;
        bottom: 24px;
        z-index: 8000;
        background: none;
        border: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 7px;
        font-family: "ObviouslyWide", system-ui, sans-serif;
        font-size: 9px;
        font-weight: 400;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(232, 228, 222, 0.35);
        writing-mode: vertical-rl;
        transition: color 0.25s ease;
      }

      .music-toggle:hover {
        color: rgba(232, 228, 222, 0.8);
      }

      .music-toggle__dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
        flex-shrink: 0;
        transition: background 0.25s ease;
      }

      .music-toggle.is-playing {
        color: rgba(232, 228, 222, 0.6);
      }

      .music-toggle.is-playing .music-toggle__dot {
        background: #986edf;
        animation: dot-pulse 2s ease-in-out infinite;
      }

      @keyframes dot-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.4; transform: scale(0.65); }
      }

      .music-toggle--on-light {
        color: rgba(26, 26, 26, 0.45);
      }

      .music-toggle--on-light:hover {
        color: rgba(26, 26, 26, 0.8);
      }

      .music-toggle--on-light.is-playing {
        color: rgba(26, 26, 26, 0.6);
      }
    </style>
  </head>
  <body>
    <!-- Brand mark — top left, hidden until past hero -->
    <div class="brand-mark" id="brand-mark" role="button" aria-label="Back to top">
      <div class="brand-mark__symbol"></div>
      <div class="brand-mark__logo"></div>
    </div>

    <!-- Grain texture — feTurbulence fractalNoise -->
    <svg class="grain" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <filter id="grain-filter" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.68"
          numOctaves="3"
          stitchTiles="stitch"
        />
        <feColorMatrix type="saturate" values="0" />
      </filter>
      <rect width="100%" height="100%" filter="url(#grain-filter)" />
    </svg>

    <slot />

    <div class="cursor-dot" id="cursor-dot"></div>

    <!-- Background music -->
    <audio id="bg-music" loop preload="none">
      <source src="/audio/website-audio.ogg" type="audio/ogg" />
    </audio>

    <button class="music-toggle" id="music-toggle" aria-label="Toggle music">
      <span class="music-toggle__dot"></span>
      <span class="music-toggle__text">Music On</span>
    </button>

    <script>
      // ── Smooth scroll (non-Safari fine pointer devices only) ──
      const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
      if (!isSafari && window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
        let currentY = window.scrollY;
        let velocity = 0;

        window.addEventListener("wheel", (e) => {
          e.preventDefault();
          currentY = window.scrollY; // re-sync in case position changed externally
          let delta = e.deltaY;
          if (e.deltaMode === 1) delta *= 28;
          if (e.deltaMode === 2) delta *= window.innerHeight;
          velocity += delta * 0.14;              // dampen input heavily
        }, { passive: false });

        (function tick() {
          velocity *= 0.80;                           // decay — eases out quickly
          if (Math.abs(velocity) > 0.1) {
            const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
            currentY = Math.max(0, Math.min(currentY + velocity, maxScroll));
            window.scrollTo(0, currentY);
          } else {
            velocity = 0;
          }
          requestAnimationFrame(tick);
        })();
      }

      const dot = document.getElementById("cursor-dot") as HTMLElement;
      const R = 4; // half of 8px dot
      let mx = 0, my = 0;
      let cx = 0, cy = 0;
      let visible = false;

      document.addEventListener("mousemove", (e) => {
        mx = e.clientX;
        my = e.clientY;
        if (!visible) {
          // Snap to position on first move so it doesn't slide in from (0,0)
          cx = mx; cy = my;
          visible = true;
        }
        dot.style.opacity = "1";
      });

      (function animate() {
        cx += (mx - cx) * 0.18;
        cy += (my - cy) * 0.18;
        dot.style.transform = `translate(${cx - R}px, ${cy - R}px)`;
        requestAnimationFrame(animate);
      })();

      // ── Brand mark: hover + click via coordinate tracking (pointer-events stays none) ──
      const brandMark     = document.getElementById("brand-mark") as HTMLElement;
      if (brandMark) {
        const hero          = document.querySelector<HTMLElement>(".hero");
        const lightSections = Array.from(document.querySelectorAll<HTMLElement>(
          ".manifesto-block--first, .manifesto-block--third"
        ));

        function updateBrandMark() {
          const pastHero = hero
            ? hero.getBoundingClientRect().bottom <= 0
            : window.scrollY > window.innerHeight * 0.8;
          brandMark.classList.toggle("is-visible", pastHero);
          const onLight = lightSections.some((s) => {
            const r = s.getBoundingClientRect();
            return r.top < window.innerHeight && r.bottom > 0;
          });
          brandMark.classList.toggle("brand-mark--on-light", onLight);
        }
        window.addEventListener("scroll", updateBrandMark, { passive: true });
        updateBrandMark();

        // Hover: check if mouse is over the brand mark area on every mousemove
        document.addEventListener("mousemove", (e) => {
          const r = brandMark.getBoundingClientRect();
          const over = e.clientX >= r.left && e.clientX <= r.right &&
                       e.clientY >= r.top  && e.clientY <= r.bottom;
          brandMark.classList.toggle("is-hovered", over);
        });

        // Click: scroll to top if click lands within brand mark bounds
        document.addEventListener("click", (e) => {
          const r = brandMark.getBoundingClientRect();
          if (e.clientX >= r.left && e.clientX <= r.right &&
              e.clientY >= r.top  && e.clientY <= r.bottom) {
            window.scrollTo({ top: 0, behavior: "smooth" });
          }
        });
      }

      // ── Music toggle ──
      const music       = document.getElementById("bg-music") as HTMLAudioElement;
      const musicToggle = document.getElementById("music-toggle") as HTMLButtonElement;

      if (music && musicToggle) {
        const musicToggleText = musicToggle.querySelector(".music-toggle__text") as HTMLElement;

        // Light/dark background detection
        const lightSectionsForToggle = Array.from(document.querySelectorAll<HTMLElement>(
          ".manifesto-block--first, .manifesto-block--third"
        ));
        function updateMusicToggleColor() {
          const tr = musicToggle.getBoundingClientRect();
          const onLight = lightSectionsForToggle.some((s) => {
            const r = s.getBoundingClientRect();
            return r.top < tr.bottom && r.bottom > tr.top;
          });
          musicToggle.classList.toggle("music-toggle--on-light", onLight);
        }
        window.addEventListener("scroll", updateMusicToggleColor, { passive: true });
        updateMusicToggleColor();

        function startMusic() {
          music.play().then(() => {
            musicToggle.classList.add("is-playing");
            if (musicToggleText) musicToggleText.textContent = "Music On";
          }).catch(() => {});
        }

        // Attempt autoplay immediately
        startMusic();

        // If blocked, play on first user interaction
        function onFirstInteraction() {
          if (music.paused) startMusic();
          document.removeEventListener("click", onFirstInteraction);
          document.removeEventListener("keydown", onFirstInteraction);
          document.removeEventListener("touchstart", onFirstInteraction);
        }
        document.addEventListener("click", onFirstInteraction);
        document.addEventListener("keydown", onFirstInteraction);
        document.addEventListener("touchstart", onFirstInteraction);

        musicToggle.addEventListener("click", (e) => {
          e.stopPropagation();
          if (music.paused) {
            startMusic();
            if (musicToggleText) musicToggleText.textContent = "Music On";
          } else {
            music.pause();
            musicToggle.classList.remove("is-playing");
            if (musicToggleText) musicToggleText.textContent = "Off";
          }
        });
      }
    </script>
  </body>
</html>
