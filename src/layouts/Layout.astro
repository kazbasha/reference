---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Reference",
  description = "Reference — Supersonic creative.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <style>
      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Regular.woff2") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Medium.woff2") format("woff2");
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Bold.woff2") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }

      *, *::before, *::after {
        box-sizing: border-box;
      }

      :root {
        color-scheme: dark;
      }

      html {
        scroll-behavior: auto;
        overflow-x: hidden;
      }

      body {
        margin: 0;
        background: #0a0a0a;
        color: #e8e4de;
        font-family: "ObviouslyWide", system-ui, -apple-system, sans-serif;
        overflow-x: hidden;
        cursor: none;
      }

      h1, h2, h3, p {
        margin: 0;
      }

      /* Grain overlay — fixed, covers entire viewport */
      .grain {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 9000;
        pointer-events: none;
        opacity: 0.038;
      }

      .grain rect {
        animation: grain-shift 9s steps(7) infinite;
      }

      @keyframes grain-shift {
        0%   { transform: translate(0,    0);    }
        14%  { transform: translate(-6%, -10%);  }
        28%  { transform: translate(4%,  -4%);   }
        42%  { transform: translate(-3%,  7%);   }
        57%  { transform: translate(6%,   3%);   }
        71%  { transform: translate(-4%, -6%);   }
        85%  { transform: translate(2%,   9%);   }
        100% { transform: translate(0,    0);    }
      }

      /* Custom cursor dot */
      .cursor-dot {
        position: fixed;
        top: 0;
        left: 0;
        width: 8px;
        height: 8px;
        background: #986edf;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        will-change: transform;
        opacity: 0;
        transition: opacity 0.2s ease;
      }
    </style>
  </head>
  <body>
    <!-- Grain texture — feTurbulence fractalNoise -->
    <svg class="grain" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <filter id="grain-filter" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.68"
          numOctaves="3"
          stitchTiles="stitch"
        />
        <feColorMatrix type="saturate" values="0" />
      </filter>
      <!-- Oversized rect so animated translate never reveals edges -->
      <rect
        width="200%"
        height="200%"
        x="-50%"
        y="-50%"
        filter="url(#grain-filter)"
      />
    </svg>

    <slot />

    <div class="cursor-dot" id="cursor-dot"></div>

    <script>
      // ── Smooth scroll (fine pointer devices only) ──
      if (window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
        let currentY = window.scrollY;
        let velocity = 0;

        window.addEventListener("wheel", (e) => {
          e.preventDefault();
          let delta = e.deltaY;
          if (e.deltaMode === 1) delta *= 28;
          if (e.deltaMode === 2) delta *= window.innerHeight;
          velocity += delta * 0.14;              // dampen input heavily
        }, { passive: false });

        (function tick() {
          velocity *= 0.80;                           // decay — eases out quickly
          if (Math.abs(velocity) > 0.1) {
            const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
            currentY = Math.max(0, Math.min(currentY + velocity, maxScroll));
            window.scrollTo(0, currentY);
          } else {
            velocity = 0;
          }
          requestAnimationFrame(tick);
        })();
      }

      const dot = document.getElementById("cursor-dot") as HTMLElement;
      const R = 4; // half of 8px dot
      let mx = 0, my = 0;
      let cx = 0, cy = 0;
      let visible = false;

      document.addEventListener("mousemove", (e) => {
        mx = e.clientX;
        my = e.clientY;
        if (!visible) {
          // Snap to position on first move so it doesn't slide in from (0,0)
          cx = mx; cy = my;
          dot.style.opacity = "1";
          visible = true;
        }
      });

      document.addEventListener("mouseleave", () => {
        dot.style.opacity = "0";
        visible = false;
      });

      document.addEventListener("mouseenter", () => {
        if (visible) dot.style.opacity = "1";
      });

      (function animate() {
        cx += (mx - cx) * 0.18;
        cy += (my - cy) * 0.18;
        dot.style.transform = `translate(${cx - R}px, ${cy - R}px)`;
        requestAnimationFrame(animate);
      })();
    </script>
  </body>
</html>
