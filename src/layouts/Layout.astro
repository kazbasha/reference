---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Reference",
  description = "Reference — Supersonic creative.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <style>
      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Regular.woff2") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Medium.woff2") format("woff2");
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "ObviouslyWide";
        src: url("/fonts/ObviouslyWide-Bold.woff2") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }

      :root {
        color-scheme: dark;
      }

      body {
        margin: 0;
        background: #04130c;
        color: rgba(255, 255, 255, 0.92);
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
