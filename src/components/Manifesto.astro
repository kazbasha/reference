// 4 rows × 3 cols — mathematically verified non-overlapping at 768px–1920px.
// Rows 1&4 (large) hug top/bottom edges; rows 2&3 (medium) flank the text.
// Images spread across different rows and columns.
const ads = [
  // ── ROW 1 — top:4%, large (270px), z:5, alpha:1 ──────────────────────
  // cols: left:7%, left:38%, left:69%
  { src: '/video/cadbury-gorilla.mp4',          pos: 'top:4%;left:7%;width:clamp(190px,19vw,270px);z-index:5',   rot: -4, alpha: 1.0,  floatDelay: '0s',   threshold: 0.04 },
  { src: '/video/axa-three-words.webp',         pos: 'top:4%;left:38%;width:clamp(190px,19vw,270px);z-index:5',  rot:  2, alpha: 1.0,  floatDelay: '0.8s', threshold: 0.34 },
  { src: '/video/long-long-man.mp4',            pos: 'top:4%;left:69%;width:clamp(190px,19vw,270px);z-index:5',  rot: -2, alpha: 1.0,  floatDelay: '1.8s', threshold: 0.58 },

  // ── ROW 2 — top:28%, medium (190px), z:3, alpha:0.85 ─────────────────
  // cols: left:11%, left:42%, left:72% — offset from row 1
  { src: '/video/audi-sheep.jpg',               pos: 'top:28%;left:11%;width:clamp(140px,13vw,190px);z-index:3',  rot:  3, alpha: 0.85, floatDelay: '3.2s', threshold: 0.10 },
  { src: '/video/dumb-ways-to-die.mp4',         pos: 'top:28%;left:42%;width:clamp(140px,13vw,190px);z-index:3',  rot: -3, alpha: 0.85, floatDelay: '0.6s', threshold: 0.40 },
  { src: '/video/never-say-no-to-panda-v2.mp4', pos: 'top:28%;left:72%;width:clamp(140px,13vw,190px);z-index:3',  rot:  1, alpha: 0.85, floatDelay: '2.4s', threshold: 0.64 },

  // ── ROW 3 — bottom:28%, medium (190px), z:3, alpha:0.85 ──────────────
