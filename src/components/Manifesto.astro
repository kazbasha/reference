<style>
  .manifesto-block {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(60px, 10vw, 140px) clamp(24px, 7vw, 100px);
    background: transparent;
    overflow: hidden;
  }

  .manifesto-block--alt {
    background: transparent;
  }

  .manifesto-block--finale {
    background: #000000;
    min-height: 100svh;
    padding: 0;
    position: relative;
    z-index: 1;
  }

  /* ── Fixed background — stays pinned behind all sections ── */
  .manifesto-bg {
    position: fixed;
    inset: 0;
    background: #0a0a0a;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .manifesto-bg::before {
    content: '';
    position: absolute;
    inset: -30%;
    background: radial-gradient(
      ellipse 55% 55% at 50% 50%,
      rgba(152, 110, 223, 0.11) 0%,
      transparent 65%
    );
    animation: glow-drift 14s ease-in-out infinite;
  }

  @keyframes glow-drift {
    0%   { transform: translate(0%,   0%); }
    25%  { transform: translate(18%, -12%); }
    50%  { transform: translate(-12%, 16%); }
    75%  { transform: translate(14%,  12%); }
    100% { transform: translate(0%,   0%); }
  }

  /* ── First section: no special bg needed, bg comes from .manifesto-bg ── */
  .manifesto-block--first {
    overflow: hidden;
  }

  /* ── Horizontal scroll text (i===1) ── */
  /* Section is a transparent scroll spacer — gives scroll distance */
  .manifesto-block--green {
    min-height: 280svh;
  }

  /* Fixed overlay — stays pinned to viewport, only visible when section is active */
  .manifesto-hscroll {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .manifesto-hscroll-text {
    white-space: nowrap;
    font-size: clamp(28px, 4.5vw, 72px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.01em;
    color: #e8e4de;
    will-change: transform;
    position: relative;
    z-index: 5; /* sits above mid/far ads (z:1,4) but below near ads (z:8) */
  }

  /* ── Ad cards ── */
  .ad-item {
    position: absolute;
    /* width is set per-item via inline style for depth effect */
    border-radius: 3px;
    overflow: hidden;
    opacity: 0;
    transform: rotate(var(--rot, 0deg)) scale(0.85) translateY(16px);
    transition:
      opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.65);
  }

  .ad-item video,
  .ad-item img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ad-item.is-visible {
    opacity: var(--alpha, 1);
    transform: rotate(var(--rot, 0deg)) scale(1) translateY(0);
    animation: ad-float 5s ease-in-out var(--float-delay, 0s) infinite;
  }

  @keyframes ad-float {
    0%, 100% { transform: rotate(var(--rot, 0deg)) scale(1) translateY(0px); }
    50%       { transform: rotate(var(--rot, 0deg)) scale(1) translateY(-7px); }
  }

/* ── Burst particle layer ── */
  .burst-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
    z-index: 3;
  }

  /* ── Perspective grid (inside fixed .manifesto-bg) ── */
  .perspective-grid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  :global(.burst-word) {
    transition: color 0.15s ease;
    cursor: none;
  }

  :global(.burst-word:hover) {
    color: #986edf;
  }

  /* ── Reveal state ── */
  .manifesto-inner {
    position: relative;
    z-index: 1;
    max-width: 860px;
    width: 100%;
    text-align: center;
  }

  .manifesto-line {
    font-size: clamp(22px, 3.6vw, 58px);
    font-weight: 400;
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: #e8e4de;
    text-wrap: balance;
    /* initial hidden state — driven by JS adding .is-visible */
    opacity: 0;
    transform: translateY(36px);
    transition:
      opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .manifesto-line--two {
    margin-top: 0.3em;
    transition-delay: 0.14s;
  }

  .manifesto-inner.is-visible .manifesto-line {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Finale portal ── */
  .contact-grid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    transform-origin: center;
    animation: grid-pulse 4s linear infinite;
  }

  @keyframes grid-pulse {
    0%   { transform: scale(1);    opacity: 0.13; }
    8%   { transform: scale(1.07); opacity: 0.28; }
    28%  { transform: scale(1);    opacity: 0.13; }
    100% { transform: scale(1);    opacity: 0.13; }
  }

  /* Morphing button — circle → rectangle */
  .contact-btn {
    position: relative;
    z-index: 2;
    width: clamp(108px, 9vw, 124px);
    height: clamp(108px, 9vw, 124px);
    border-radius: 50%;
    background: transparent;
    border: 1px solid rgba(152, 110, 223, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    overflow: hidden;
    transition:
      width 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      border-radius 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.3s ease,
      background 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .contact-btn:hover {
    width: clamp(240px, 22vw, 320px);
    border-radius: 4px;
    border-color: rgba(152, 110, 223, 0.7);
    background: #0d0318;
  }

  .contact-btn-label {
    position: absolute;
    max-width: 60px;
    text-align: center;
    color: #986edf;
    font-size: clamp(7px, 0.65vw, 9px);
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1.65;
    white-space: normal;
    padding: 0 12px;
    /* on hover-out: wait for email to finish fading before reappearing */
    transition: opacity 0.2s ease 0.28s;
  }

  .contact-btn:hover .contact-btn-label {
    opacity: 0;
    /* on hover-in: fade out immediately */
    transition: opacity 0.15s ease;
  }

  .contact-btn-email {
    position: absolute;
    color: rgba(152, 110, 223, 0.85);
    font-size: clamp(9px, 0.8vw, 11px);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: lowercase;
    white-space: nowrap;
    opacity: 0;
    /* on hover-out: fade out quickly with no delay */
    transition: opacity 0.18s ease;
  }

  .contact-btn:hover .contact-btn-email {
    opacity: 1;
    /* on hover-in: fade in after shape has expanded */
    transition: opacity 0.25s ease 0.38s;
  }
</style>

<script>
  // ── Reveal on scroll ──
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target); // fire once
        }
      });
    },
    {
      threshold: 0.22,
      rootMargin: "0px 0px -40px 0px",
    }
  );

  document.querySelectorAll("[data-reveal]").forEach((el) => observer.observe(el));

  // ── Parallax + perspective on manifesto sections ──
  function applyParallax() {
    const inners = document.querySelectorAll<HTMLElement>(".manifesto-inner.is-visible");
    const vh = window.innerHeight;

    inners.forEach((inner) => {
      const rect     = inner.getBoundingClientRect();
      const progress = (vh / 2 - (rect.top + rect.height / 2)) / vh;
      const clamped  = Math.max(-0.8, Math.min(0.8, progress));
      const translateY = clamped * -110;
      const rotateX    = clamped * 7;
      inner.style.transform = `perspective(900px) rotateX(${rotateX}deg) translateY(${translateY}px)`;
    });
  }

  // ── Horizontal scroll text ──
  const hscrollSection   = document.querySelector<HTMLElement>('.manifesto-block--green');
  const hscrollContainer = hscrollSection?.querySelector<HTMLElement>('.manifesto-hscroll');
  const hscrollText      = hscrollContainer?.querySelector<HTMLElement>('.manifesto-hscroll-text');

  if (hscrollSection && hscrollContainer && hscrollText) {
    const section   = hscrollSection;
    const container = hscrollContainer;
    const text      = hscrollText;
    const adItems   = Array.from(container.querySelectorAll<HTMLElement>('.ad-item'));
    // Size the section so scroll distance = full text travel (vpW → -textW)
    const textW = text.scrollWidth;
    const vpW   = window.innerWidth;
    const vpH   = window.innerHeight;
    section.style.minHeight = `${textW + vpW + vpH}px`;

    function applyHscroll() {
      const rect        = section.getBoundingClientRect();
      const vh          = window.innerHeight;
      const sh          = section.offsetHeight;
      const active      = rect.top < vh && rect.bottom > 0;
      container.style.opacity = active ? '1' : '0';
      const scrollRange = sh - vh;
      const progress    = Math.max(0, Math.min(1, -rect.top / scrollRange));
      // Travel from right edge of viewport → fully off-screen left
      const tw = text.scrollWidth;
      const vw = window.innerWidth;
      const tx = vw - progress * (vw + tw);
      text.style.transform = `translateX(${tx}px)`;
      adItems.forEach((item) => {
        if (progress >= parseFloat(item.dataset.threshold ?? '0')) {
          item.classList.add('is-visible');
        }
      });
    }

    window.addEventListener("scroll", applyHscroll, { passive: true });
    applyHscroll();
  }

  window.addEventListener("scroll", applyParallax, { passive: true });
  applyParallax();

</script>

<style>
  /* Parallax transform applied directly via JS — no transition so it tracks scroll instantly */
  .manifesto-inner.is-visible {
    transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Prevent the parallax transform competing with line transitions */
  .manifesto-inner.is-visible .manifesto-line,
  .manifesto-inner--finale.is-visible .manifesto-finale {
    transform: none;
  }
</style>

<script>
  const burstWord  = document.querySelector('.burst-word');
  const burstLayer = document.querySelector<HTMLElement>('.burst-layer');

  if (burstWord && burstLayer) {
    const word = burstWord as Element;
    function rand(a: number, b: number) { return a + Math.random() * (b - a); }

    const BG = `fill="#e8e4de"`;
    const S  = `stroke="#1a1a1a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"`;
    const H  = `<circle cx="20" cy="20" r="17" ${BG}/>`;   // filled head
    const FACES = [
      // WOW — round eyes, raised brows, O-mouth
      `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" ${S}>${H}<path d="M9,10 Q13,7 17,10"/><path d="M23,10 Q27,7 31,10"/><circle cx="13" cy="16" r="3.5"/><circle cx="27" cy="16" r="3.5"/><ellipse cx="20" cy="27" rx="5" ry="5.5"/></svg>`,
      // LAUGHING — squint eyes, open grin
      `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" ${S}>${H}<path d="M9,15 Q13,10 17,15"/><path d="M23,15 Q27,10 31,15"/><path d="M10,23 Q15,21 20,22 Q25,21 30,23"/><path d="M10,23 Q20,36 30,23"/></svg>`,
      // SHOCKED — rect eyes, raised brows, oval mouth
      `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" ${S}>${H}<path d="M9,10 Q13,7 17,10"/><path d="M23,10 Q27,7 31,10"/><rect x="10" y="12" width="8" height="7" rx="1"/><rect x="22" y="12" width="8" height="7" rx="1"/><ellipse cx="20" cy="28" rx="5" ry="5.5"/></svg>`,
      // THINKING — one raised brow, eyes looking up, chin touch
      `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" ${S}>${H}<path d="M9,13 Q13,10 17,13"/><path d="M22,11 Q27,8 31,12"/><circle cx="13" cy="17" r="2.5"/><circle cx="27" cy="15" r="2.5"/><path d="M15,27 Q18,25 22,26"/><path d="M26,31 Q28,29 30,27"/></svg>`,
      // CRAZY — swirl eye + X eye, wavy grin
      `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" ${S}>${H}<circle cx="13" cy="16" r="5"/><circle cx="13" cy="16" r="2"/><path d="M23,11 L31,21"/><path d="M31,11 L23,21"/><path d="M9,27 Q12,24 15,27 Q18,30 21,27 Q24,24 27,27"/></svg>`,
      // SMUG — arched brow, hooded eye, lopsided smirk
      `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" ${S}>${H}<path d="M9,12 Q13,9 17,12"/><path d="M22,10 Q27,8 31,12"/><circle cx="13" cy="17" r="2.5"/><circle cx="27" cy="16" r="2.5"/><path d="M24,13.5 Q27,12 30,13.5"/><path d="M13,26 Q18,24 22,26 Q26,29 28,27"/></svg>`,
      // STAR-EYED — asterisk eyes, big smile
      `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" ${S}>${H}<path d="M13,10.5 L13,20.5 M8,15.5 L18,15.5 M9.5,12 L16.5,19 M16.5,12 L9.5,19"/><path d="M27,10.5 L27,20.5 M22,15.5 L32,15.5 M23.5,12 L30.5,19 M30.5,12 L23.5,19"/><path d="M10,26 Q20,36 30,26"/></svg>`,
      // DISGUSTED — furrowed brows, squinted lines, frown
      `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" ${S}>${H}<path d="M9,14 Q13,17 17,14"/><path d="M23,14 Q27,17 31,14"/><line x1="10" y1="17" x2="16" y2="17"/><line x1="24" y1="17" x2="30" y2="17"/><path d="M12,28 Q20,23 28,28"/></svg>`,
    ];

    function spawnBurst() {
      const rect = word.getBoundingClientRect();

      for (let i = 0; i < 8; i++) {
        const size = rand(48, 72);
        const el   = document.createElement('div');
        el.style.cssText = `position:fixed;pointer-events:none;z-index:9998;width:${size}px;height:${size}px;top:0;left:0;`;
        el.innerHTML = FACES[Math.floor(Math.random() * FACES.length)];
        document.body.appendChild(el);

        let x   = rect.left + rand(0, rect.width)  - size / 2;
        let y   = rect.top  + rand(-6, 6)           - size / 2;
        let vx  = rand(-2, 2);
        let vy  = rand(-7, -4);
        let rot = rand(0, 360);
        const vr = rand(-1.5, 1.5);
        (function tick() {
          vy  += 0.1;
          x   += vx;
          y   += vy;
          rot += vr;
          el.style.transform = `translate(${x}px,${y}px) rotate(${rot}deg)`;
          if (y < window.innerHeight + size) requestAnimationFrame(tick);
          else el.remove();
        })();
      }
    }

    word.addEventListener('mouseenter', spawnBurst);
  }
</script>
