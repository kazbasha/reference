  // ── ROW 4 — bottom:4%, large (270px), z:5, alpha:1 ───────────────────
  // cols: left:15%, left:45%, left:74% — offset from row 1
  { src: '/video/nothing-beats-a-londoner.mp4', pos: 'bottom:4%;left:15%;width:clamp(190px,19vw,270px);z-index:5', rot:  2, alpha: 1.0,  floatDelay: '1.1s', threshold: 0.16 },
