  { src: '/video/snickers.mp4',                 pos: 'bottom:28%;left:4%;width:clamp(140px,13vw,190px);z-index:3', rot: -2, alpha: 0.85, floatDelay: '1.5s', threshold: 0.22 },
  { src: '/video/volvo-splits.mp4',             pos: 'bottom:28%;left:35%;width:clamp(140px,13vw,190px);z-index:3', rot:  4, alpha: 0.85, floatDelay: '2.9s', threshold: 0.46 },
