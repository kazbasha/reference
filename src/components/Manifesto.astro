<div class="manifesto">
  {
    blocks.map(([line1, line2], i) => (
      <section class:list={["manifesto-block", { "manifesto-block--alt": i % 2 !== 0, "manifesto-block--first": i === 0, "manifesto-block--green": i === 1 }]}>
        {i === 1
          ? <div class="manifesto-hscroll">
              {ads.map((ad) => {
                const isImg = /\.(jpg|png|webp)$/.test(ad.src);
                return (
                  <div
                    class="ad-item"
                    data-threshold={ad.threshold}
                    style={`${ad.pos};--rot:${ad.rot}deg;--float-delay:${ad.floatDelay};--alpha:${ad.alpha}`}
                  >
                    {isImg
                      ? <img src={ad.src} alt="" loading="lazy" />
                      : <video autoplay loop muted playsinline><source src={ad.src} type="video/mp4" /></video>
                    }
                  </div>
                );
              })}
              <p class="manifesto-hscroll-text">{line1}{"   "}{line2}</p>
            </div>
          : <div class="manifesto-inner" data-reveal>
              <p class="manifesto-line">{line1}</p>
              {i === 0
                ? <p class="manifesto-line manifesto-line--two" set:html={line2.replace('Fuck', '<span class="burst-word">Fuck</span>')} />
                : <p class="manifesto-line manifesto-line--two">{line2}</p>
              }
            </div>
        }
        {i === 0 && <div class="burst-layer"></div>}
      </section>
    ))
  }

  <!-- Closing CTA — portal -->
  <section class="manifesto-block manifesto-block--finale">

    <!-- Flat regular grid — visible outside the portal -->
    <svg
      class="contact-grid"
      viewBox="0 0 1600 900"
      preserveAspectRatio="xMidYMid slice"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
