---
---

<section class="hero">
  <!-- Background video — drop /public/video/hero.mp4 to activate -->
  <div class="hero-bg" aria-hidden="true">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="/video/hero.mp4" type="video/mp4" />
    </video>
  </div>

  <!-- Vignette overlay -->
  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- Content -->
  <div class="hero-content">
    <img
      class="hero-logo"
      src="/brand/reference-logo.svg"
      alt="Reference — Supersonic Creative"
    />
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-track">
      <div class="scroll-thumb"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100svh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0a0a0a;
  }

  /* ── Background video ── */
  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 1;
    /* Slightly oversized so parallax shift never reveals edges */
    transform: scale(1.12);
    will-change: transform;
  }

  /* CSS fallback shown when no video file is present */
  .hero-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 90% 70% at 50% 40%,
        rgba(18, 18, 28, 0.9),
        transparent 80%
      ),
      radial-gradient(
        ellipse 60% 50% at 70% 60%,
        rgba(12, 16, 22, 0.7),
        transparent 70%
      );
  }

  /* ── Vignette ── */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to bottom,
        rgba(10, 10, 10, 0.1) 0%,
        transparent 15%,
        transparent 80%,
        rgba(10, 10, 10, 0.35) 100%
      );
    pointer-events: none;
  }

  /* ── Copy ── */
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .hero-logo {
    width: clamp(180px, 36vw, 580px);
    height: auto;
    display: block;
    will-change: transform;
    /* Recolor logo to off-white #e8e4de: crush to black → invert to white → warm tint */
    filter: brightness(0) invert(1) brightness(0.92) sepia(0.12);
    animation: logo-spin 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  @keyframes logo-spin {
    0%   { opacity: 0; transform: perspective(1400px) rotateY(75deg) scale(0.94); }
    65%  { opacity: 1; transform: perspective(1400px) rotateY(-6deg)  scale(1.01); }
    100% { opacity: 1; transform: perspective(1400px) rotateY(0deg)   scale(1);   }
  }

  /* ── Scroll indicator ── */
  .scroll-indicator {
    position: absolute;
    bottom: clamp(28px, 4vw, 52px);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    animation: reveal 1.6s cubic-bezier(0.16, 1, 0.3, 1) 1.4s both;
  }

  .scroll-track {
    position: relative;
    width: 1px;
    height: 54px;
    background: rgba(255, 255, 255, 0.15);
    overflow: hidden;
  }

  /* Animated thumb — travels top to bottom, loops */
  .scroll-thumb {
    position: absolute;
    top: -100%;
    left: 0;
    width: 100%;
    height: 40%;
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(255, 255, 255, 0.8),
      transparent
    );
    animation: scroll-travel 2.6s cubic-bezier(0.4, 0, 0.6, 1) 1.8s infinite;
  }

  @keyframes scroll-travel {
    0%   { top: -40%; }
    100% { top: 100%; }
  }

  @keyframes reveal {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0);    }
  }
</style>

<script>
  const hero  = document.querySelector<HTMLElement>(".hero");
  const video = document.querySelector<HTMLVideoElement>(".hero-video");
  const logo  = document.querySelector<HTMLImageElement>(".hero-logo");

  // ── Parallax on scroll ──
  const heroContent = document.querySelector<HTMLElement>(".hero-content");
  const scrollIndicator = document.querySelector<HTMLElement>(".scroll-indicator");

  if (hero) {
    window.addEventListener(
      "scroll",
      () => {
        const scrollY = window.scrollY;
        const heroH = hero.offsetHeight;
        if (scrollY > heroH) return;
        const progress = scrollY / heroH;

        // Video drifts up slowly (deep layer)
        if (video) {
          video.style.transform = `scale(1.12) translateY(${-progress * 7}%)`;
        }

        // Logo drifts up at ~1/3 scroll speed and fades out (mid layer)
        if (heroContent) {
          heroContent.style.transform = `translateY(${-progress * 28}%)`;
          heroContent.style.opacity = String(Math.max(0, 1 - progress * 2.2));
        }

        // Scroll indicator fades out quickly
        if (scrollIndicator) {
          scrollIndicator.style.opacity = String(Math.max(0, 1 - progress * 5));
        }
      },
      { passive: true }
    );
  }

  // ── Logo 3D cursor tilt ──
  if (hero && logo) {
    let targetX = 0, targetY = 0;
    let currentX = 0, currentY = 0;
    let tiltActive = false;

    // Wait for intro spin to finish, then release the animation so JS
    // can own the transform. Without clearing it, fill-mode:both overrides
    // inline styles in the cascade.
    setTimeout(() => {
      logo.style.animation = "none";
      tiltActive = true;
    }, 1800);

    hero.addEventListener("mousemove", (e) => {
      if (!tiltActive) return;
      const rect = hero.getBoundingClientRect();
      const cx = rect.left + rect.width  / 2;
      const cy = rect.top  + rect.height / 2;
      // Normalize -1 → 1 from center; clamp to prevent edge extremes
      const nx = Math.max(-1, Math.min(1, (e.clientX - cx) / (rect.width  / 2)));
      const ny = Math.max(-1, Math.min(1, (e.clientY - cy) / (rect.height / 2)));
      targetY =  nx * 8;   // horizontal mouse → rotateY
      targetX = -ny * 5;   // vertical mouse   → rotateX (inverted so it tips toward cursor)
    });

    hero.addEventListener("mouseleave", () => {
      targetX = 0;
      targetY = 0;
    });

    (function animate() {
      const ease = 0.07;
      currentX += (targetX - currentX) * ease;
      currentY += (targetY - currentY) * ease;

      if (tiltActive) {
        logo.style.transform =
          `perspective(1400px) rotateX(${currentX}deg) rotateY(${currentY}deg)`;
      }

      requestAnimationFrame(animate);
    })();
  }
</script>
